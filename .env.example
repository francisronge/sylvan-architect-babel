GEMINI_API_KEY=your_gemini_api_key_here
# Optional overrides:
# Primary defaults to gemini-3.1-pro-preview
# GEMINI_MODEL=gemini-3.1-pro-preview
# Pro defaults to gemini-3.1-pro-preview
# GEMINI_PRO_MODEL=gemini-3.1-pro-preview
# Payload transcriber defaults to gemini-3.1-flash-lite-preview
# Used only as a last-resort structural repair gate after primary parse failure.
# GEMINI_PAYLOAD_TRANSCRIBER_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_PAYLOAD_TRANSCRIBER_MAX_OUTPUT_TOKENS=16384
# GEMINI_PAYLOAD_TRANSCRIBER_TIMEOUT_MS=45000
# GEMINI_PAYLOAD_TRANSCRIBER_TEMPERATURE=0
# --- Security hardening (recommended for deployment) ---
# Trust-proxy setting for Express (default: 1 in production, false in local runtime).
# BABEL_TRUST_PROXY=1
# Optional strict origin allow-list for /api/parse (comma-separated full origins).
# Example: BABEL_ALLOWED_ORIGINS=https://babel.example.com,https://www.babel.example.com
# BABEL_ALLOWED_ORIGINS=
# Require Origin checks in production (default: true in production, false in local runtime).
# BABEL_REQUIRE_ORIGIN=true
# Allow requests without Origin header (default: false in production).
# BABEL_ALLOW_NO_ORIGIN=false
# API token gate for /api/parse  *** REQUIRED in production / Vercel ***
# If set, clients must send header: x-babel-api-token: <token>
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BABEL_PARSE_API_TOKEN=replace_with_long_random_token
# Optional dev-server host allowlist for Vite when intentionally tunneling or exposing dev previews.
# Example: BABEL_DEV_ALLOWED_HOSTS=.trycloudflare.com
# BABEL_DEV_ALLOWED_HOSTS=
# Rate and abuse controls:
# BABEL_PARSE_RATE_LIMIT_PER_MINUTE=30
# BABEL_PARSE_DAILY_LIMIT_PER_IP=1200
# BABEL_MAX_IN_FLIGHT_PARSES=8
# Optional global timeout override for both models:
# GEMINI_MODEL_TIMEOUT_MS=90000
# If global timeout is unset, defaults are model-specific:
# GEMINI_PRIMARY_TIMEOUT_MS=90000
# GEMINI_PRO_TIMEOUT_MS=120000
# Optional parse corpus logging (use a pooled Postgres connection string).
# Example: BABEL_PARSE_LOG_DATABASE_URL=postgresql://postgres:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# BABEL_PARSE_LOG_DATABASE_URL=
